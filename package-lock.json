{
  "name": "keyrail",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "keyrail",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "bin": {
        "keyrail": "packages/cli/bin/keyrail.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@keyrail/backends": {
      "resolved": "packages/backends",
      "link": true
    },
    "node_modules/@keyrail/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@keyrail/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@keyrail/policy": {
      "resolved": "packages/policy",
      "link": true
    },
    "packages/backends": {
      "name": "@keyrail/backends",
      "version": "0.1.0"
    },
    "packages/cli": {
      "name": "@keyrail/cli",
      "version": "0.1.0",
      "dependencies": {
        "@keyrail/backends": "0.1.0",
        "@keyrail/core": "0.1.0",
        "@keyrail/policy": "0.1.0"
      },
      "bin": {
        "keyrail": "bin/keyrail.js"
      }
    },
    "packages/core": {
      "name": "@keyrail/core",
      "version": "0.1.0"
    },
    "packages/policy": {
      "name": "@keyrail/policy",
      "version": "0.1.0"
    }
  }
}
